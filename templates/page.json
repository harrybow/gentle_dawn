orm:uppercase;color:#bbb\">EAN</span><span id=\"lb-ean-val\"></span></div>\n      <div style=\"width:32px;height:2px;background:var(--g);margin-bottom:20px\"></div>\n      <div id=\"lb-uvp-label\" style=\"font-size:10px;letter-spacing:.14em;color:var(--m);margin-bottom:4px\">UVP ENDKUNDE</div>\n      <div id=\"lb-uvp\" style=\"font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:var(--d)\"></div>\n      <div id=\"lb-uvp-sub\" style=\"font-size:11px;color:var(--m);margin-top:3px\"></div>\n    </div>\n  </div>\n</div>\n<div class=\"wrap\" id=\"main\">\n<div class=\"hdr\">\n  <div><div class=\"bl\" id=\"lbl-tagline\">Handgemacht in Berlin</div><div class=\"bn\">Gentle Gin.</div><div class=\"bs\" id=\"lbl-sub\">B2B Bestellformular 2026</div></div>\n  <div style=\"text-align:right\">\n    <img src=\"data:image/png;base64,\" style=\"width:72px;height:auto;display:block;margin-left:auto\" alt=\"Gentle Gin\"/>\n    <div class=\"tg\">keep it gentle!</div>\n    <button id=\"lang-btn\" onclick=\"toggleLang()\" style=\"margin-top:8px;padding:4px 12px;border:1px solid var(--g);background:transparent;color:var(--g);border-radius:12px;font-size:10px;letter-spacing:.15em;cursor:pointer;font-family:inherit\">EN</button>\n  </div>\n</div>\n<div class=\"gd\"></div>\n<form id=\"frm\" action=\"https://formspree.io/f/meergeby\" method=\"POST\" style=\"display:none\">\n  <input type=\"hidden\" name=\"_subject\" value=\"Neue Gentle Gin B2B Bestellung\"/>\n  <input type=\"hidden\" name=\"_replyto\" id=\"fe\"/><input type=\"hidden\" name=\"Firma\" id=\"fc\"/>\n  <input type=\"hidden\" name=\"Ansprechpartner\" id=\"fct\"/><input type=\"hidden\" name=\"Anschrift\" id=\"fa\"/>\n  <input type=\"hidden\" name=\"PLZ_Ort\" id=\"fz\"/><input type=\"hidden\" name=\"Telefon\" id=\"fp\"/>\n  <input type=\"hidden\" name=\"Bestellung\" id=\"fo\"/><input type=\"hidden\" name=\"Staffel\" id=\"ft\"/>\n  <input type=\"hidden\" name=\"Netto\" id=\"fn\"/><input type=\"hidden\" name=\"USt\"